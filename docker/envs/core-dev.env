# Non-secret dev wiring (tokens live in secret-envs/veil-core.env).
# These are localhost values so a BARE dev run (uvicorn/celery on the host,
# no Docker) works out of the box. docker/dev.yml overrides the hostnames
# (redis service name, host.docker.internal, /app/weights) via `environment:`.
REDIS_URL=redis://localhost:6379/0
WEB_CALLBACK_URL=http://localhost:3000
CUDA=false
